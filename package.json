{
  "name": "@secpal/contracts",
  "version": "0.0.1",
  "description": "OpenAPI specifications and TypeScript types for SecPal API",
  "license": "AGPL-3.0-or-later",
  "author": "SecPal Contributors",
  "homepage": "https://github.com/SecPal/contracts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SecPal/contracts.git"
  },
  "bugs": {
    "url": "https://github.com/SecPal/contracts/issues"
  },
  "keywords": [
    "openapi",
    "typescript",
    "api",
    "contracts",
    "secpal"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openapi"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "generate": "npx openapi-typescript openapi/main.yaml -o src/types/api.ts",
    "validate": "npx --yes @redocly/cli lint openapi/main.yaml",
    "lint": "npx eslint . --ext .ts",
    "format": "npx prettier --write \"**/*.{ts,yaml,yml,json,md}\"",
    "format:check": "npx prettier --check \"**/*.{ts,yaml,yml,json,md}\"",
    "test": "echo 'No tests yet' && exit 0",
    "test:coverage": "echo 'No tests yet' && exit 0",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.4.2",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
